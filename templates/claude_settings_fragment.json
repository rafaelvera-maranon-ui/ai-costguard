{
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:4040",
    "ANTHROPIC_AUTH_TOKEN": "sk-costguard-local",
    "ANTHROPIC_MODEL": "cg-standard",
    "CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "4096",
    "CLAUDE_CODE_MAX_TURNS": "12",
    "CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY": "3",
    "MAX_THINKING_TOKENS": "4000",
    "PATH": "$HOME/.costguard/bin:$PATH"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.costguard/hooks/pre_tool_use.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.costguard/hooks/post_tool_use.py"
          }
        ]
      }
    ]
  }
}
