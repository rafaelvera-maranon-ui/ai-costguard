COSTGUARD_HOST=127.0.0.1
COSTGUARD_PORT=4040
COSTGUARD_LOCAL_API_KEY=sk-costguard-local

# OpenAI-compatible inference endpoint, used by Cline.
OPENAI_UPSTREAM_BASE_URL=
OPENAI_UPSTREAM_API_KEY=
OPENAI_MODEL_CHEAP=
OPENAI_MODEL_STANDARD=
OPENAI_MODEL_STRONG=

# Anthropic-compatible inference endpoint, used by Claude Code CLI validation.
# Leave empty unless your provider exposes an Anthropic Messages-compatible API.
ANTHROPIC_UPSTREAM_BASE_URL=
ANTHROPIC_UPSTREAM_API_KEY=
ANTHROPIC_MODEL_CHEAP=
ANTHROPIC_MODEL_STANDARD=
ANTHROPIC_MODEL_STRONG=

COSTGUARD_DEFAULT_MODEL=cg-standard
COSTGUARD_LOG_CONTENT=false
COSTGUARD_ENABLE_SECRET_FILTER=true
COSTGUARD_ENABLE_OUTPUT_LIMITS=true
COSTGUARD_MAX_OUTPUT_CHARS=20000
COSTGUARD_MAX_OUTPUT_LINES=500

COSTGUARD_DAILY_BUDGET=5
COSTGUARD_MONTHLY_BUDGET=100
COSTGUARD_BUDGET_MODE=warn

# Optional model pricing catalog.
# This is NOT the model inference endpoint above. It should be a catalog endpoint
# that returns model metadata and prices, for example inputPrice/outputPrice.
# Leave empty unless your company/provider exposes one.
# Auth can reuse an existing local .env key or use a separate shell/local variable.
# Examples:
# COSTGUARD_PRICING_API_KEY_ENV=OPENAI_UPSTREAM_API_KEY
# COSTGUARD_PRICING_API_KEY_ENV=PRICING_API_KEY
# Do not commit real company endpoints or API keys.
COSTGUARD_PRICING_URL=
COSTGUARD_PRICING_API_KEY_ENV=
COSTGUARD_PRICING_API_KEY=
COSTGUARD_PRICING_AUTH_HEADER=x-api-key
COSTGUARD_PRICING_AUTH_SCHEME=

COSTGUARD_CACHE_MODE=disabled
# Response cache is exact-match and disabled for content by default.
# Set true only on a trusted local workstation if you accept storing prompts/responses locally.
COSTGUARD_CACHE_STORE_CONTENT=false
COSTGUARD_CACHE_TTL_SECONDS=86400
# Limits apply to cache/responses only; pricing cache is separate.
COSTGUARD_CACHE_MAX_ENTRIES=1000
COSTGUARD_CACHE_MAX_SIZE_MB=100
COSTGUARD_CACHE_EVICTION_POLICY=lru
COSTGUARD_HEADROOM_ENABLED=false
